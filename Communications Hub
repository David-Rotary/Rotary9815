<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>District 9815 — Communications &amp; Public Image Hub</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
/* ─── RESET ─────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Source Sans 3',sans-serif;font-size:13px;background:#f2f6fb;color:#1c2840;line-height:1.65;}
a{text-decoration:none;color:inherit;}
button{font-family:'Source Sans 3',sans-serif;cursor:pointer;}

/* ─── TOKENS ─────────────────────────────────── */
:root{
  --blue:#005daa;
  --blue-dark:#002f5e;
  --blue-mid:#1572c8;
  --blue-light:#e6f0fa;
  --gold:#f0a500;
  --gold-light:#fff8e6;
  --green:#1a8a5a;
  --green-light:#e6f7f0;
  --rose:#c0392b;
  --rose-light:#fde8e6;
  --purple:#5c3fa0;
  --purple-light:#ede9fe;
  --teal:#0e7a8a;
  --teal-light:#e0f7fa;
  --border:#d8e4f0;
  --shadow-sm:0 2px 8px rgba(0,47,94,.07);
  --shadow-md:0 6px 22px rgba(0,47,94,.1);
  --shadow-lg:0 14px 40px rgba(0,47,94,.13);
  --r:14px;
}

/* ─── STICKY HEADER ─────────────────────────── */
#app-header{
  position:sticky;top:0;z-index:400;
  background:linear-gradient(120deg,var(--blue) 0%,var(--blue-dark) 100%);
  color:#fff;
  box-shadow:0 3px 24px rgba(0,0,60,.22);
}
.hbar{
  max-width:1300px;margin:0 auto;
  padding:13px 24px;
  display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;
}
.hbrand{display:flex;align-items:center;gap:13px;}
.hlogo{
  width:40px;height:40px;border-radius:50%;
  background:var(--gold);display:flex;align-items:center;justify-content:center;
  font-size:17px;flex-shrink:0;box-shadow:0 2px 8px rgba(0,0,0,.18);
}
.hname{font-family:'Sora',sans-serif;font-size:14px;font-weight:700;line-height:1.2;}
.hname span{display:block;font-size:10.5px;font-weight:400;opacity:.7;margin-top:1px;letter-spacing:.3px;}
.hactions{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.hactions button{
  font-size:12px;font-weight:600;border:none;border-radius:8px;padding:8px 14px;transition:.18s;
}
.btn-gold{background:var(--gold);color:#1c2840;}
.btn-gold:hover{filter:brightness(1.07);transform:translateY(-1px);}
.btn-ghost{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.2);}
.btn-ghost:hover{background:rgba(255,255,255,.2);}

/* ─── GUIDE PANEL ────────────────────────────── */
#guide-panel{
  display:none;
  background:#00244e;
  border-top:1px solid rgba(255,255,255,.1);
}
.gp-inner{
  max-width:1300px;margin:0 auto;
  padding:15px 24px;
  display:flex;gap:18px;align-items:flex-start;flex-wrap:wrap;
}
.gp-body{flex:1;min-width:220px;}
.gp-label{
  font-size:9.5px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--gold);margin-bottom:6px;
}
#gp-text{font-size:12.5px;color:rgba(255,255,255,.9);white-space:pre-line;line-height:1.75;}
.gp-nav{display:flex;gap:8px;align-items:center;flex-wrap:wrap;padding-top:11px;}
.gp-nav button{
  font-size:12px;font-weight:600;border:none;border-radius:8px;padding:7px 14px;transition:.15s;
}
.btn-gnext{background:var(--gold);color:#1c2840;}
.btn-gnext:hover{filter:brightness(1.08);}
.btn-gback{background:rgba(255,255,255,.1);color:#fff;}
.btn-gback:hover{background:rgba(255,255,255,.2);}
.btn-gexit{background:rgba(220,38,38,.18);color:#fca5a5;border:1px solid rgba(220,38,38,.28);}
.btn-gexit:hover{background:rgba(220,38,38,.3);}
.step-dots{display:flex;gap:5px;align-items:center;margin-left:auto;}
.sdot{
  width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.22);
  transition:.22s;cursor:pointer;
}
.sdot.active{background:var(--gold);transform:scale(1.35);}

/* ─── TAB NAV ────────────────────────────────── */
#tab-nav{
  background:#fff;border-bottom:2px solid var(--border);
  position:sticky;top:63px;z-index:300;
  box-shadow:0 2px 10px rgba(0,47,94,.05);
}
.tn-inner{
  max-width:1300px;margin:0 auto;
  padding:0 24px;
  display:flex;gap:0;overflow-x:auto;scrollbar-width:none;
}
.tn-inner::-webkit-scrollbar{display:none;}
.tnav-tab{
  font-family:'Sora',sans-serif;
  font-size:11.5px;font-weight:600;
  color:#6b7e9a;padding:13px 17px;
  border-bottom:3px solid transparent;
  cursor:pointer;transition:.18s;white-space:nowrap;flex-shrink:0;
}
.tnav-tab:hover{color:var(--blue);}
.tnav-tab.active{color:var(--blue);border-bottom-color:var(--blue);}

/* ─── HERO SECTION ───────────────────────────── */
.page-hero{
  background:linear-gradient(135deg,var(--blue) 0%,var(--blue-dark) 55%,#001630 100%);
  color:#fff;padding:50px 24px 38px;position:relative;overflow:hidden;
}
.page-hero::before{
  content:'';position:absolute;inset:0;
  background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.hero-inner{max-width:1300px;margin:0 auto;position:relative;}
.hero-eyebrow{
  display:inline-block;
  font-size:10.5px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--gold);margin-bottom:14px;
}
.hero-inner h1{
  font-family:'Sora',sans-serif;
  font-size:clamp(22px,3vw,32px);font-weight:800;
  line-height:1.15;margin-bottom:12px;
}
.hero-inner h1 em{font-style:normal;color:var(--gold);}
.hero-inner p{
  font-size:13px;color:rgba(255,255,255,.8);
  max-width:680px;line-height:1.7;margin-bottom:20px;
}
.hero-pills{display:flex;gap:8px;flex-wrap:wrap;}
.hpill{
  font-size:11px;font-weight:600;padding:5px 12px;
  border-radius:20px;border:1px solid rgba(255,255,255,.25);
  color:#fff;background:rgba(255,255,255,.1);
  backdrop-filter:blur(4px);
}

/* ─── MAIN CONTENT ───────────────────────────── */
.main{max-width:1300px;margin:0 auto;padding:28px 24px 70px;}
.section{display:none;animation:fadeUp .3s ease both;}
.section.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* ─── SECTION TITLE ──────────────────────────── */
.sec-title{
  display:flex;align-items:center;gap:14px;margin-bottom:24px;
}
.sec-icon{
  width:48px;height:48px;border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;flex-shrink:0;
}
.sec-title h2{
  font-family:'Sora',sans-serif;font-size:18px;font-weight:700;color:var(--blue-dark);
}
.sec-title p{font-size:12px;color:#6b7e9a;margin-top:3px;}

/* ─── STAT ROW ───────────────────────────────── */
.stat-row{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:26px;}
.stat-card{
  background:#fff;border-radius:var(--r);padding:16px 20px;
  box-shadow:var(--shadow-sm);text-align:center;min-width:105px;flex:1;
  border-top:3px solid var(--blue);
}
.stat-card.gold{border-top-color:var(--gold);}
.stat-card.green{border-top-color:var(--green);}
.stat-card.purple{border-top-color:var(--purple);}
.stat-card.teal{border-top-color:var(--teal);}
.s-num{font-family:'Sora',sans-serif;font-size:26px;font-weight:800;color:var(--blue);}
.stat-card.gold .s-num{color:var(--gold);}
.stat-card.green .s-num{color:var(--green);}
.stat-card.purple .s-num{color:var(--purple);}
.stat-card.teal .s-num{color:var(--teal);}
.s-lbl{font-size:11px;color:#7b8eaa;margin-top:2px;font-weight:600;}

/* ─── CARD GRID ──────────────────────────────── */
.card-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(290px,1fr));
  gap:18px;margin-bottom:28px;
}
@media(max-width:640px){.card-grid{grid-template-columns:1fr;}}

/* ─── ACCORDION CARD ─────────────────────────── */
.acard{
  background:#fff;border-radius:var(--r);
  border:2px solid transparent;
  box-shadow:var(--shadow-sm);
  overflow:hidden;cursor:pointer;
  transition:transform .2s,box-shadow .2s,border-color .2s;
}
.acard:hover{transform:translateY(-3px);box-shadow:var(--shadow-md);}
.acard.open{border-color:var(--blue);}
.acard.guided{border-color:var(--gold);box-shadow:0 0 0 3px rgba(240,165,0,.2);}

.acard-head{
  display:flex;align-items:flex-start;justify-content:space-between;
  padding:18px 18px 14px;gap:12px;
}
.ah-icon{
  width:44px;height:44px;border-radius:12px;
  background:var(--blue-light);
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;
}
.ah-body{flex:1;}
.ah-body strong{
  font-family:'Sora',sans-serif;font-size:13px;font-weight:700;
  color:var(--blue-dark);display:block;
}
.ah-body p{font-size:12px;color:#7b8eaa;margin-top:3px;line-height:1.45;}
.ah-badges{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px;}
.badge{font-size:10.5px;font-weight:700;padding:3px 9px;border-radius:20px;}
.b-blue  {background:var(--blue-light);   color:#1e40af;}
.b-green {background:var(--green-light);  color:#166534;}
.b-amber {background:var(--gold-light);   color:#92400e;}
.b-purple{background:var(--purple-light); color:#5b21b6;}
.b-red   {background:var(--rose-light);   color:#991b1b;}
.b-teal  {background:var(--teal-light);   color:#065f46;}
.ah-chev{font-size:11px;color:#adb8c8;transition:transform .28s;flex-shrink:0;padding-top:3px;}
.acard.open .ah-chev{transform:rotate(90deg);}

.acard-body{max-height:0;overflow:hidden;transition:max-height .38s ease;}
.acard.open .acard-body{max-height:1400px;}
.acard-body-inner{padding:0 18px 18px;border-top:1px solid #edf2f7;}

/* ─── RESOURCE LINKS ─────────────────────────── */
.rlinks{display:flex;flex-direction:column;gap:7px;margin-top:14px;}
.rlinks a{
  display:flex;justify-content:space-between;align-items:center;
  background:#f6f9fc;border:1px solid var(--border);
  padding:11px 14px;border-radius:10px;
  color:var(--blue);font-size:12px;font-weight:600;
  transition:.18s;
}
.rlinks a:hover{background:var(--blue-light);transform:translateX(4px);}
.rl-arr{opacity:.45;font-size:13px;}
.rl-tag{font-size:9.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;
  padding:2px 7px;border-radius:6px;margin-left:auto;margin-right:8px;}
.rl-pdf{background:var(--rose-light);color:#991b1b;}
.rl-link{background:var(--green-light);color:#166534;}

/* ─── PROMPT BOXES ───────────────────────────── */
.prompt{margin-top:13px;padding:11px 14px;border-radius:10px;font-size:12px;line-height:1.6;}
.pr-gold  {background:var(--gold-light);  border-left:3px solid var(--gold);  color:#78350f;}
.pr-blue  {background:var(--blue-light);  border-left:3px solid var(--blue);  color:#1e3a5f;}
.pr-green {background:var(--green-light); border-left:3px solid var(--green); color:#14532d;}
.pr-purple{background:var(--purple-light);border-left:3px solid var(--purple);color:#3b1f6e;}
.pr-red   {background:var(--rose-light);  border-left:3px solid var(--rose);  color:#7f1d1d;}

/* ─── CHECKLIST ──────────────────────────────── */
.checklist{display:flex;flex-direction:column;gap:6px;margin-top:12px;}
.ck-item{
  display:flex;align-items:flex-start;gap:10px;
  padding:9px 12px;background:#f6f9fc;
  border-radius:9px;font-size:12px;
  border:1px solid #edf2f7;transition:.15s;cursor:pointer;
}
.ck-item:hover{background:var(--blue-light);}
.ck-item input{margin-top:2px;flex-shrink:0;cursor:pointer;accent-color:var(--blue);}
.ck-item.done{
  background:var(--green-light);border-color:#bbf7d0;
  color:#166534;text-decoration:line-through;opacity:.8;
}

/* ─── MATRIX GRID ────────────────────────────── */
.matrix{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
  gap:10px;margin-top:14px;
}
.mx-cell{
  background:#f6f9fc;border-radius:10px;padding:14px;
  border-left:3px solid var(--blue);
}
.mx-cell.gold  {border-color:var(--gold);}
.mx-cell.green {border-color:var(--green);}
.mx-cell.purple{border-color:var(--purple);}
.mx-cell.teal  {border-color:var(--teal);}
.mx-cell.rose  {border-color:var(--rose);}
.mx-title{font-family:'Sora',sans-serif;font-size:11.5px;font-weight:700;color:var(--blue-dark);margin-bottom:5px;}
.mx-body{font-size:11.5px;color:#4a5568;line-height:1.55;}

/* ─── PROGRESS SLIDERS ───────────────────────── */
.slider-wrap{margin-bottom:18px;}
.slider-label{
  display:flex;justify-content:space-between;align-items:center;
  font-size:12px;font-weight:600;color:#4a5568;margin-bottom:6px;
}
.slider-pct{
  font-family:'Sora',sans-serif;font-size:12px;
  font-weight:700;color:var(--blue);
  background:var(--blue-light);padding:2px 8px;border-radius:20px;
}
.slider-track{background:#e2ecf5;border-radius:20px;height:7px;overflow:hidden;margin-bottom:7px;}
.slider-bar{height:100%;border-radius:20px;background:var(--blue);transition:width .4s ease;}
input[type=range]{width:100%;accent-color:var(--blue);height:4px;border-radius:4px;cursor:pointer;}

/* ─── QUARTERLY TIMELINE ─────────────────────── */
.q-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(210px,1fr));
  gap:14px;margin-top:4px;
}
.q-card{
  background:#fff;border-radius:var(--r);
  border:2px solid var(--border);padding:18px;
  transition:.2s;position:relative;overflow:hidden;
}
.q-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
}
.q-card:nth-child(1)::before{background:var(--blue);}
.q-card:nth-child(2)::before{background:var(--gold);}
.q-card:nth-child(3)::before{background:var(--green);}
.q-card:nth-child(4)::before{background:var(--purple);}
.q-card:hover{border-color:var(--blue);transform:translateY(-2px);box-shadow:var(--shadow-sm);}
.q-label{
  font-family:'Sora',sans-serif;
  font-size:10px;font-weight:700;letter-spacing:1.8px;
  text-transform:uppercase;color:var(--blue);margin-bottom:10px;
}
.q-items{display:flex;flex-direction:column;gap:6px;}
.q-item{font-size:12px;color:#374151;padding:5px 0;border-bottom:1px dashed #e5ebf2;}
.q-item:last-child{border:none;}

/* ─── DIVIDER ────────────────────────────────── */
hr.dvd{border:none;border-top:1px solid var(--border);margin:26px 0;}

/* ─── PIPELINE STEPS ─────────────────────────── */
.pipeline{display:flex;flex-direction:column;gap:0;margin-top:14px;}
.pipe-step{
  display:flex;gap:14px;align-items:flex-start;
  padding:12px 0;border-bottom:1px dashed #dde6f0;
}
.pipe-step:last-child{border:none;}
.pipe-num{
  width:28px;height:28px;border-radius:50%;
  background:var(--blue);color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-family:'Sora',sans-serif;font-size:12px;font-weight:700;
  flex-shrink:0;margin-top:1px;
}
.pipe-num.gold  {background:var(--gold);color:#1c2840;}
.pipe-num.green {background:var(--green);}
.pipe-num.purple{background:var(--purple);}
.pipe-num.teal  {background:var(--teal);}
.pipe-content strong{font-size:12.5px;font-weight:700;color:var(--blue-dark);display:block;margin-bottom:3px;}
.pipe-content p{font-size:12px;color:#4a5568;line-height:1.55;}

/* ─── TEAM ROLES ─────────────────────────────── */
.team-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:12px;margin-top:14px;
}
.team-role{
  background:#f6f9fc;border-radius:10px;padding:14px;
  border:1px solid var(--border);transition:.18s;
}
.team-role:hover{background:var(--blue-light);border-color:var(--blue);}
.tr-icon{font-size:20px;margin-bottom:7px;}
.tr-title{font-family:'Sora',sans-serif;font-size:12.5px;font-weight:700;color:var(--blue-dark);margin-bottom:4px;}
.tr-desc{font-size:11.5px;color:#6b7e9a;line-height:1.5;}

/* ─── CHAIR INTRO ────────────────────────────── */
.chair-intro{
  display:flex;gap:16px;align-items:flex-start;
  background:#f6f9fc;border:1px solid var(--border);
  border-radius:12px;padding:16px;margin-top:14px;
}
.chair-avatar{
  width:58px;height:58px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,var(--blue),var(--blue-dark));
  color:#fff;font-family:'Sora',sans-serif;font-weight:800;font-size:18px;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 14px rgba(0,47,94,.22);
}
.chair-text{font-size:12px;color:#4a5568;line-height:1.6;}
.chair-text strong{color:var(--blue-dark);}

/* ─── ANIMATION DELAYS FOR CARDS ─────────────── */
.card-grid .acard:nth-child(1){animation-delay:.05s;}
.card-grid .acard:nth-child(2){animation-delay:.1s;}
.card-grid .acard:nth-child(3){animation-delay:.15s;}
@keyframes cardIn{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
.section.active .acard{animation:cardIn .35s ease both;}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════════
     STICKY HEADER
══════════════════════════════════════════════════ -->
<div id="app-header">
  <div class="hbar">
    <div class="hbrand">
      <div class="hlogo">📣</div>
      <div class="hname">
        District 9815 — Communications &amp; Public Image Hub
        <span>Awareness · Recruitment · Fundraising · Rotary Year 2025–26</span>
      </div>
    </div>
    <div class="hactions">
      <button class="btn-gold" id="startGuide">▶ Guided Flow</button>
      <button class="btn-ghost" onclick="expandAll()">Expand All</button>
      <button class="btn-ghost" onclick="collapseAll()">Collapse All</button>
    </div>
  </div>

  <!-- GUIDED FLOW PANEL -->
  <div id="guide-panel">
    <div class="gp-inner">
      <div class="gp-body">
        <div class="gp-label" id="gp-label">Step 1 of 9</div>
        <div id="gp-text"></div>
        <div class="gp-nav">
          <button class="btn-gback" id="gp-prev">← Back</button>
          <button class="btn-gnext" id="gp-next">Next →</button>
          <button class="btn-gexit" id="gp-exit">Exit</button>
          <div class="step-dots" id="step-dots"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════
     TAB NAVIGATION
══════════════════════════════════════════════════ -->
<div id="tab-nav">
  <div class="tn-inner">
    <div class="tnav-tab active" data-tab="overview">📋 Overview</div>
    <div class="tnav-tab" data-tab="image">✨ Public Image</div>
    <div class="tnav-tab" data-tab="promote">📣 Promote Your Club</div>
    <div class="tnav-tab" data-tab="website">🌐 Website</div>
    <div class="tnav-tab" data-tab="social">📱 Social Media</div>
    <div class="tnav-tab" data-tab="content">📰 Content &amp; Bulletins</div>
    <div class="tnav-tab" data-tab="planner">📅 Year Planner</div>
  </div>
</div>

