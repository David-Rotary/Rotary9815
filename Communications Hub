      const headerH = document.getElementById('app-header').offsetHeight
                    + document.getElementById('tab-nav').offsetHeight;
      window.scrollTo({ top: card.getBoundingClientRect().top + window.scrollY - headerH - 18, behavior: 'smooth' });
    }, 90);
  }

  const prev = document.getElementById('gp-prev');
  prev.disabled      = index === 0;
  prev.style.opacity = index === 0 ? '0.4' : '1';
  document.getElementById('gp-next').textContent = index === steps.length - 1 ? 'Finish ✓' : 'Next →';
  buildDots();
}

document.getElementById('startGuide').addEventListener('click', () => {
  guidePanel.style.display = 'block';
  showStep(0);
});
document.getElementById('gp-next').addEventListener('click', () => {
  if (current < steps.length - 1) showStep(current + 1);
  else document.getElementById('gp-exit').click();
});
document.getElementById('gp-prev').addEventListener('click', () => {
  if (current > 0) showStep(current - 1);
});
document.getElementById('gp-exit').addEventListener('click', () => {
  guidePanel.style.display = 'none';
  acards.forEach(c => c.classList.remove('guided', 'open'));
  window.scrollTo({ top: 0, behavior: 'smooth' });
});
</script>
</body>
</html>
