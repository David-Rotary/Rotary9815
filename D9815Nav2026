<script>
(function(){
  var root = document.getElementById('d9815-start');
  if(!root){ return; }
  /* Friendly time-of-day greeting (falls back to the static welcome if JS is off) */
  var h = new Date().getHours();
  var greeting = h < 12 ? 'Good morning' : (h < 18 ? 'Good afternoon' : 'Good evening');
  var eb = root.querySelector('.d9-eyebrow');
  if(eb){ eb.textContent = greeting; }

  var cards = root.querySelectorAll('.d9-card');
  var secs  = root.querySelectorAll('.d9-sec');

  function select(key){
    cards.forEach(function(c){
      c.setAttribute('aria-pressed', c.getAttribute('data-key') === key ? 'true' : 'false');
    });
    secs.forEach(function(s){
      s.classList.toggle('is-on', s.getAttribute('data-sec') === key);
    });
  }

  cards.forEach(function(c){
    c.addEventListener('click', function(){ select(c.getAttribute('data-key')); });
  });
})();
</script>
